# Copy to .env.local (gitignored) and fill in. NEVER commit real values.

# --- Supabase (server-side; RLS is OFF in this dev mockup) ---
NEXT_PUBLIC_SUPABASE_URL=https://dsvtqjnjdxvvjvrgvgep.supabase.co
# Service-role key from Supabase dashboard -> Project Settings -> API.
# Server-only: used by the intake server actions to read the catalog and write
# the prospect. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (server-side ONLY; never sent to the client) ---
OPENAI_API_KEY=sk-...
# Model id is read from env. Example default:
OPENAI_MODEL=gpt-4o-mini
