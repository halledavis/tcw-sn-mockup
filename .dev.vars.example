# Local secrets for `wrangler dev` / `opennextjs-cloudflare preview` (the
# Cloudflare Workers runtime). Copy to .dev.vars (gitignored) and fill in.
# `next dev` does NOT use this file — it reads .env.local.
#
# Non-secret vars (NEXT_PUBLIC_SUPABASE_URL, OPENAI_MODEL) live in
# wrangler.jsonc -> "vars" and don't need to be here.
#
# For the DEPLOYED Worker, set these as secrets instead of committing them:
#   wrangler secret put SUPABASE_SERVICE_ROLE_KEY
#   wrangler secret put OPENAI_API_KEY

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=sk-...
